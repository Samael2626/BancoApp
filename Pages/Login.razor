@page "/login"
@using BancoApp.Services
@inject BancoService Banco
@inject NavigationManager Nav

<div class="ghost-login-page bg-grid">
    <!-- Floating particles background -->
    <div class="particles">
        <div class="particle p1"></div>
        <div class="particle p2"></div>
        <div class="particle p3"></div>
        <div class="particle p4"></div>
        <div class="particle p5"></div>
    </div>

    <div class="ghost-login-wrapper">
        <!-- Terminal-style header -->
        <div class="terminal-header ghost-enter ghost-enter-1">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-path">~/banco/auth/login</span>
        </div>

        <div class="ghost-login-card glass-card ghost-enter ghost-enter-2">
            <!-- Logo + Title -->
            <div class="login-header">
                <div class="ghost-logo">
                    <span class="logo-icon">⚡</span>
                    <div class="logo-ring"></div>
                </div>
                <h1 class="ghost-title">Banki</h1>
                <p class="ghost-subtitle">
                    <span class="ghost-typewriter">banca digital segura</span>
                </p>
            </div>

            <div class="ghost-divider"></div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="ghost-alert ghost-alert-error">
                    <span class="alert-icon">⚠</span> @_error
                </div>
            }

            <!-- Form -->
            <div class="login-form ghost-enter ghost-enter-3">
                <div class="ghost-field">
                    <label class="ghost-label">▸ usuario</label>
                    <input @bind="_usuario" type="text" placeholder="ingresa tu usuario..." class="ghost-input" id="login-usuario" />
                </div>
                <div class="ghost-field ghost-enter ghost-enter-4">
                    <label class="ghost-label">▸ contraseña</label>
                    <input @bind="_contrasena" type="password" placeholder="••••••••" class="ghost-input" id="login-password" />
                </div>
            </div>

            <button class="ghost-btn ghost-btn-primary ghost-enter ghost-enter-5" @onclick="IniciarSesion" id="btn-login">
                <span class="btn-text">▶ Ingresar</span>
            </button>

            <div class="login-footer ghost-enter ghost-enter-6">
                <span class="footer-text">¿No tienes cuenta?</span>
                <a class="ghost-link" @onclick="GoRegister">crear_cuenta()</a>
            </div>

            <!-- Status line -->
            <div class="status-bar ghost-enter ghost-enter-7">
                <span class="status-dot online"></span>
                <span class="status-text">sistema operativo</span>
                <span class="status-version">v2.0.26</span>
            </div>
        </div>
    </div>
</div>

<style>
    .ghost-login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gradient-dark);
        position: relative;
        overflow: hidden;
    }

    /* Particles */
    .particles { position: absolute; inset: 0; pointer-events: none; }
    .particle {
        position: absolute;
        width: 2px;
        height: 2px;
        background: var(--accent-cyan);
        border-radius: 50%;
        opacity: 0.4;
        animation: floatParticle 15s linear infinite;
    }
    .p1 { top: 20%; left: 10%; animation-duration: 12s; width: 3px; height: 3px; }
    .p2 { top: 60%; left: 80%; animation-duration: 18s; animation-delay: -5s; }
    .p3 { top: 80%; left: 30%; animation-duration: 14s; animation-delay: -3s; }
    .p4 { top: 10%; left: 70%; animation-duration: 20s; animation-delay: -8s; opacity: 0.2; }
    .p5 { top: 50%; left: 50%; animation-duration: 16s; animation-delay: -10s; }

    @@keyframes floatParticle {
        0% { transform: translateY(0) translateX(0) scale(1); opacity: 0; }
        10% { opacity: 0.5; }
        90% { opacity: 0.5; }
        100% { transform: translateY(-100vh) translateX(50px) scale(0.5); opacity: 0; }
    }

    /* Wrapper */
    .ghost-login-wrapper {
        width: 100%;
        max-width: 420px;
        padding: 1.5rem;
        z-index: 1;
    }

    /* Terminal Header */
    .terminal-header {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0.6rem 1rem;
        background: rgba(18, 20, 32, 0.95);
        border: 1px solid var(--border-ghost);
        border-bottom: none;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .terminal-dot {
        width: 10px; height: 10px; border-radius: 50%;
    }
    .terminal-dot.red { background: #ff5f57; }
    .terminal-dot.yellow { background: #febc2e; }
    .terminal-dot.green { background: #28c840; }
    .terminal-path {
        margin-left: auto;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--text-muted);
        letter-spacing: 0.5px;
    }

    /* Login Card */
    .ghost-login-card {
        padding: 2.5rem;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        position: relative;
    }

    /* Logo */
    .login-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .ghost-logo {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 70px;
        height: 70px;
        margin-bottom: 1rem;
    }

    .logo-icon {
        font-size: 2.2rem;
        z-index: 1;
        filter: drop-shadow(0 0 10px rgba(94, 234, 212, 0.5));
    }

    .logo-ring {
        position: absolute;
        inset: 0;
        border: 2px solid rgba(94, 234, 212, 0.15);
        border-radius: 50%;
        animation: borderGlow 3s ease-in-out infinite;
    }

    .login-header .ghost-title {
        font-size: 2.2rem;
        margin-bottom: 0.3rem;
    }

    .login-header .ghost-subtitle {
        min-height: 1.2rem;
    }

    /* Form */
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ghost-field {
        display: flex;
        flex-direction: column;
    }

    /* Footer */
    .login-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
    }

    .footer-text {
        color: var(--text-muted);
        margin-right: 0.5rem;
    }

    /* Status bar */
    .status-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-ghost);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .status-dot {
        width: 6px; height: 6px; border-radius: 50%;
    }
    .status-dot.online {
        background: var(--accent-green);
        box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
        animation: pulse 2s ease-in-out infinite;
    }
    .status-version { margin-left: auto; }
</style>

@code {
    private string _usuario = "";
    private string _contrasena = "";
    private string _error = "";

    protected override void OnInitialized()
    {
        if (Banco.Autenticado) Nav.NavigateTo("/dashboard");
    }

    private void IniciarSesion()
    {
        _error = "";
        if (!Banco.Login(_usuario, _contrasena))
            _error = Banco.LastLoginError ?? "Usuario o contraseña incorrectos.";
        else
            Nav.NavigateTo("/dashboard");
    }

    private void GoRegister() => Nav.NavigateTo("/registro");
}
